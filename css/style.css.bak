.hoverbox4 img
{
	display:block;
}
.hoverbox5 img
{
	display:block;
}
.hoverbox6 img
{
	display:block;
}

.overimg1
{
	background:var(--overimg);
	display:none;
	color:white;
	box-sizing:border-box;
	transition:1s;
	margin:20px;
	opacity:0.9;
}
.overimg1clr
{
	height:4px;
	width:80px;
	background:var(--commnclr);
	margin-left:0px;
}
.overimg1clr1
{
	height:4px;
	width:80px;
	background:var(--commnclr);
	margin-left:217px;
}
.overimg1 h3
{
	color:var(--headbacgnd);
	line-height:15px;
	padding-top:40px;
}
.overimg1 span
{
	color:var(--conclr);
}
.icon1
{
	font-size:18px;
	margin-top:10px;
	margin-bottom:120px;
}
.icon1 i
{
	border:1px solid var(--hovrbox);
	padding:12px;
	border-radius:50%;
	margin:0px;
	color:var(--hvrbxclr);
	height:18px;
	width:18px;
	cursor:pointer;
}
.hoverbox1:hover img
{
	display:none;
}
.hoverbox2:hover img
{
	display:none;
}
.hoverbox3:hover img
{
	display:none;
}
.hoverbox4:hover img
{
	display:none;
}
.hoverbox5:hover img
{
	display:none;
}
.hoverbox6:hover img
{
	display:none;
}
.hoverbox2:hover .overimg1
{
	display:block;
	transition:1s;
}
.hoverbox1:hover .overimg1
{
	display:block;
	transition:1s;
}
.hoverbox3:hover .overimg1
{
	display:block;
	transition:1s;
}
.hoverbox4:hover .overimg1
{
	display:block;
	transition:1s;
}
.hoverbox5:hover .overimg1
{
	display:block;
	transition:1s;
}
.hoverbox6:hover .overimg1
{
	display:block;
	transition:1s;
}
	/*----------------========PARTNERS======----------------*/

.partlogo
{
	padding:80px 0px 80px 130px;
	background:var(--commnclr);
	margin-right:0px;
}
.imgpart
{
	width:18%;
	display:inline-block;
}
.imgpart img
{
	width:100%;
}
	/*----------------========HIRING======----------------*/

.hiring
{
	padding:80px 70px;
}
.leftsidebox
{
	width:35%;
	height:480px;
	float:left;
	background:url('../images/contact1.jpg') no-repeat center;
	background-size:cover;
	margin-left:30px;
}
.overleft
{
	background:var(--hiringclr);
	height:100%;
	color:white;
	text-align:center;
	padding-top:80px;
	box-sizing:border-box;
	opacity:0.8;
}
.overleft h3
{
	color:var(--commnclr);
}
.overleft h2
{
	line-height:38px;
	font-size:26px;
	margin-top:20px;
}
.rightmap
{
	width:58%;
	height:480px;
	float:right;
	background:white;
}
.rightmap iframe
{
	width:100%;
	height:100%;
	border:0px;
}
	/*----------------========TESTIMONIAL======----------------*/

.testimonial
{
	background:var(--commnclr);
	padding:80px 0;
	text-align:center;
}
.title h3
{
	color:var(--whiteclr);
	letter-spacing:2px;
	font-size:18px;
	margin:0px;
}
.title h1
{
	color:var(--whiteclr);
	font-size:40px;
	margin:10px 0px;
}
.title p
{
	color:var(--whiteclr);
	width:60%;
	line-height:26px;
	font-size:16px;
	padding-left:280px;
}
.testimonialbox
{
	width:100%;
	margin:auto;
}
.boxtest
{
	background:var(--whiteclr);
	width:35%;
	padding:30px;
	display:inline-block;
	margin:10px;
	text-align:left;
}
.top img
{
	width:60px;
	height:60px;
	border-radius:50%;
	float:left;
	margin-right:15px;
}
.info h3
{
	color:var(--commnclr);
	vertical-align:top;
}
.info span
{
	font-size:14px;
	color:var(--commnclr);
	font-weight:bold;
	vertical-align:top;
}
.boxtest p
{
	margin-top:20px;
	line-height:24px;
	color:var(--conclr);
	clear:both;
}
.star
{
	margin-top:15px;
}
.star i
{
	font-size:18px;
	color:var(--commnclr);
	margin-right:3px;
}
/*----------------========CONTACT FORM======----------------*/

.contactform
{
	text-align:center;
	padding:60px 0px;
}
.contactform h1
{
	color:var(--headbacgnd);
	font-size:36px;
	margin-bottom:10px;
}
.contactform p
{
	color:var(--conclr);
	font-size:16px;
	line-height:24px;
	padding-left:180px;
	padding-right:180px;
}
.continform
{
	margin-top:40px;
}
.informbox
{
	display:inline-block;
	width:30%;
	text-align:center;
}
.informbox i
{
	font-size:30px;
	color:var(--commnclr);
	margin-bottom:10px;
}
.informbox h4
{
	color:var(--headbacgnd);
	margin:5px 0;
}
.informbox p
{
	color:var(--headbacgnd);
	font-weight:700;
	padding-left:50px;
	padding-right:50px;
	text-align:center;
}
.contact-form
{
	background:var(--whiteclr);
	margin-top:40px;
	margin-left:80px;
	margin-right:80px;
	padding:40px;
	border-radius:10px;
	box-shadow:3px 3px 10px 3px var(--boxsha);
}
.form
{
	width:500px;
	border:1px solid red;
	text-align:left;
	background:var(--commnclr);
	border-radius:6px;
	padding:10px;
	color:var(--whiteclr);
	display:inline-block;
	margin-right:20px;
	margin-top:20px;
	font-size:14px;
}
.comment
{
	width:1000px;
	height:100px;
	border:1px solid red;
	text-align:left;
	background:var(--commnclr);
	border-radius:6px;
	padding:30px;
	color:var(--commentclr);
	display:inline-block;
	margin-right:20px;
	margin-top:20px;
	font-size:14px;
}
.contimg
{
	margin-top:80px;
	margin-bottom:20px;
	padding:0px;
}
.contimg img
{
	width:18%;
	margin-right:20px;
}
	/*----------------========OUR NEWS======----------------*/

.ournews
{
	padding:0px 70px 70px 70px;
	text-align:center;
}
.ournews h1
{
	color:var(--headbacgnd);
	font-size:36px;
	margin-bottom:10px;
}
.ournews p
{
	color:var(--conclr);
	font-size:16px;
	line-height:24px;
	padding-left:180px;
	padding-right:180px;
}
.card
{
	width:30%;
	display:inline-block;
	background:white;
	margin:10px;
	vertical-align:top;
	transition:1s;
}
.card img
{
	width:100%;
	display:block;
}
.card:hover
{
	transition:1s;
	box-shadow:0px 4px 10px gray;
}
.overlay
{
	background:var(--overlayback);
	color:white;
	padding:18px;
	font-size:18px;
	font-weight:bold;
	margin-top:-90px;
	opacity:0.9;
}
.read1
{
	margin-top:40px;
	margin-bottom:30px;
}
.read1 a
{
	color:var(--headbacgnd);
	height:20px;
	width:150px;
	font-size:16px;
	font-weight:400;
	padding:15px;	
	border-radius:4px;
	text-decoration:none;
	transition:1s;
}
.read1 a:hover
{
	color:white;
	background:var(--headbacgnd);		
	transition:1s;
}
	/*----------------========INNOVATIVE======----------------*/

.innovative
{
	background:var(--commnclr);
	padding:70px 30px 50px 130px;
}
.innovative h1
{
	font-size:40px;
	color:white;
}
.read2
{
	display:inline-block;
	margin-left:70px;
}
.read2 a
{
	color:var(--commnclr);
	height:20px;
	width:150px;
	font-size:16px;
	font-weight:400;
	padding:20px;	
	border-radius:4px;
	text-decoration:none;
	transition:1s;
	background:white;
}
.read2 a:hover
{
	color:white;
	background:var(--headbacgnd);		
	transition:1s;
}
	/*----------------========FOOTER======----------------*/

.footer1
{
	background:var(--footbckclr);
	padding:80px 120px;
}
.foot1container
{
	width:100%;
}
.foot1box
{
	width:20%;
	display:inline-block;
	vertical-align:top;
	margin-right:2%;
}
.foot1box h3
{
	color:white;
	margin-bottom:20px;
}
.foot1box a
{
	display:block;
	color:var(--footclr);
	text-decoration:none;
	margin-bottom:12px;
}
.foot1box a:hover
{
	color:white;
}
.foot1box p
{
	line-height:24px;
	margin-bottom:15px;
	color:var(--footclr);
}
.email
{
	width:213px;
	border:1px solid var(--emailbor);
	color:var(--emailclr);
	margin-top:10px;
}
.email i
{
	color:white;
	background:var(--commnclr);
	padding:18px;
}
.footer2
{
	border-top:1px solid var(--foot2);
	padding:20px 0;
	background:var(--footbckclr);
}
.copy
{
	float:left;
	color:var(--footclr);
	padding-left:120px;
	padding-bottom:10px;
}
.menu1
{
	float:right;
	padding-right:120px;
}
.menu1 a
{
	color:var(--footclr);
	text-decoration:none;
	margin-left:20px;
}
.menu1 a:hover
{
color:white;
}
.fclear
{
	clear:both;
}
/*----------============ MOBILE VIEW 320px – 480px =================-------*/

@media (min-width:320px) and (max-width:480px)
{

	.maindiv
	{
		width:100%;
	}
/*-----------HEADER-----------*/
	.header
	{
		padding:10px;
		text-align:center;
	}
	.logo
	{
		float:none;
		padding:0;
		margin-top:20px;
	}
	.logo img
	{
		width:140px;
	}
	.menu
	{
		margin-left:30px;
		display:inline-block;
		text-align:center;

	}
	.menu a
	{
		display:inline-block;
		margin:8px 5px;
		font-size:14px;
	}
	.cont
	{
		display:block;
		margin-top:10px;
		margin-left:40px;
	}
/*-----------WELCOME-----------*/
	.welcome
	{
		background-size:cover;
	}
	.social
	{
		display:inline;
	}
	.context
	{
		float:none;
		width:100%;
		height:auto;
		padding:190px 20px 60px;
		text-align:center;
	}
	.context h2
	{
		font-size:20px;
		margin-bottom:5px;
	}
	.context h1
	{
		font-size:35px;
		line-height:38px;
	}
	.context p
	{
		font-size:15px;
		margin-top:20px;
	}
	.contact
	{
		float:none;
		margin:20px auto;
	}
/*-----------ABOUT-----------*/
	.about
	{
		height:auto;
		padding:40px 20px;
	}
	.about-image
	{
		width:100%;
		float:none;
		margin:0;
	}
	.about-content
	{
		width:100%;
		float:none;
		margin-top:20px;
	}
	.about-content h
	{
		font-size:17px;
	}
	.about-content h1
	{
		font-size:26px;
	}
	.about-list li
	{
		font-size:14px;
	}
	.contact1
	{
		float:none;
		margin-top:30px;
	}
/*-----------ABOUT BOX-----------*/
	.border
	{
		padding:20px;
	}
	.box
	{
		width:100%;
		float:none;
		margin:15px 0;
		padding:20px;
	}
/*-----------COUNTING-----------*/
	.countingbox
	{
		height:auto;
		padding:30px 20px;
		text-align:center;
	}
	.counter-box
	{
		width:100%;
		float:none;
		margin:20px 0;
	}
/*-----------SERVICE-----------*/
	.service
	{
		padding:40px 20px;
	}
	.service h1
	{
		font-size:28px;
	}
	.service p
	{
		padding:0;
	}
	.servicebox
	{
		padding:20px 0;
	}
	.boxser
	{
		width:100%;
		float:none;
		margin:15px 0;
	}
/*-----------TIMER-----------*/
	.timer-section
	{
		padding:50px 10px;
	}
	.timer-box
	{
		width:60px;
		height:60px;
		padding:10px;
	}
	.timer-box h1
	{
		font-size:20px;
	}
	.timer-section span
	{
		font-size:30px;
		margin:0 5px;
	}
/*-----------PROJECT-----------*/
	.recentwork
	{
		padding:40px 20px;
	}
	.recentwork p
	{
		padding:0;
	}
	.ourwork a
	{
		display:inline-block;
		margin:5px;
	}
	.projectimg
	{
		padding:10px;
	}
	.projectbox
	{
		width:100%;
		margin:10px 0;
	}
/*-----------VIDEO-----------*/
	.video
	{
		padding:120px 0;
	}
	.video h1
	{
		font-size:24px;
	}
/*-----------TEAM-----------*/
	.hoverbox1 .overimg1
	{
		padding:40px 10px;
	}

	/*-----------PARTNER LOGO-----------*/

	.partlogo
	{
		padding:30px 10px;
		text-align:center;
	}
	.imgpart
	{
		width:45%;
		margin:10px 5px;
	}

	/*-----------HIRING-----------*/

	.hiring
	{
		padding:30px 10px;
	}
	.leftsidebox
	{
		width:100%;
		float:none;
		margin:0;
		height:400px;
	}
	.rightmap
	{
		width:100%;
		float:none;
		margin-top:20px;
		height:300px;
	}

	/*-----------TESTIMONIAL-----------*/

	.title p
	{
		width:80%;
		padding:0;
	}
	.boxtest
	{
		width:80%;
	}

	/*-----------CONTACT-----------*/

	.contactform p
	{
		padding:0 20px;
	}
	.informbox
	{
		width:100%;
		margin-bottom:20px;
	}
	.contact-form
	{
		margin:20px;
		padding:20px;
	}
	.form
	{
		width:80%;
		margin-right:0;
	}
	.comment
	{
		width:80%;
	}

	/*-----------CONTACT IMAGE-----------*/

	.contimg img
	{
		width:45%;
		margin:5px;
	}

	/*-----------NEWS-----------*/

	.ournews p
	{
		padding:0;
	}
	.card
	{
		width:90%;
	}

	/*-----------INNOVATIVE-----------*/

	.innovative
	{
		padding:30px 20px;
		text-align:center;
	}
	.innovative h1
	{
		font-size:22px;
	}
	.read2
	{
		display:block;
		margin:20px auto;
	}

	/*-----------FOOTER-----------*/

	.footer1
	{
		padding:40px 20px;
	}
	.foot1box
	{
		width:100%;
		margin-bottom:20px;
	}
	.copy
	{
		float:none;
		text-align:center;
		padding:0;
	}
	.menu1
	{
		float:none;
		text-align:center;
		padding:0;
		margin-top:10px;
	}
	.menu1 a
	{
		margin:0 10px;
	}

}